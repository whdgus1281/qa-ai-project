# ml_better.py
from sklearn.tree import DecisionTreeClassifier
from sklearn.model_selection import train_test_split
from sklearn.metrics import accuracy_score

# =============================================
# ① 데이터 — 이번엔 특징 3개!
# =============================================

# [응답시간, 에러코드(1=있음/0=없음), 하루발생횟수]
X = [
    [0.5, 0, 1],   # Minor
    [0.8, 0, 2],   # Minor
    [1.2, 0, 1],   # Minor
    [1.5, 1, 3],   # Minor
    [2.1, 1, 5],   # Critical
    [3.2, 1, 8],   # Critical
    [4.5, 1, 10],  # Critical
    [5.0, 1, 15],  # Critical
    [0.3, 0, 1],   # Minor
    [2.5, 1, 6],   # Critical
    [1.8, 0, 2],   # Minor
    [3.8, 1, 9],   # Critical
]

# 0 = Minor, 1 = Critical
y = [0, 0, 0, 0, 1, 1, 1, 1, 0, 1, 0, 1]

# =============================================
# ② 학습/테스트 데이터 나누기
# =============================================

# AI도 시험을 봐야 해요!
# 데이터 80%로 학습, 20%로 시험
# random_state=42 → 매번 같은 방식으로 나눠요
X_train, X_test, y_train, y_test = train_test_split(
    X, y,
    test_size=0.2,      # 20%는 시험용
    random_state=42
)

print(f"학습 데이터: {len(X_train)}개")
print(f"시험 데이터: {len(X_test)}개")

# =============================================
# ③ 모델 학습
# =============================================

model = DecisionTreeClassifier()
model.fit(X_train, y_train)  # 학습 데이터로만 공부!
print("✅ 학습 완료!")

# =============================================
# ④ 모델 성능 평가 (시험 점수!)
# =============================================

# 시험 데이터로 예측
y_pred = model.predict(X_test)

# 정확도 계산 (맞은 개수 / 전체)
accuracy = accuracy_score(y_test, y_pred)
print(f"🎯 AI 정확도: {accuracy * 100:.1f}%")

# =============================================
# ⑤ 실제로 써보기
# =============================================

# 새 버그 입력 [응답시간, 에러코드, 발생횟수]
새버그들 = [
    [0.5, 0, 1],   # 빠르고 에러없고 1번 → Minor?
    [4.0, 1, 12],  # 느리고 에러있고 12번 → Critical?
    [1.5, 1, 4],   # 중간 → ?
]

print("\n=== 버그 심각도 자동 판단 ===")
for 버그 in 새버그들:
    결과 = model.predict([버그])
    심각도 = "🔴 Critical" if 결과[0] == 1 else "🟡 Minor"
    print(f"응답:{버그[0]}초 | 에러:{버그[1]} | 발생:{버그[2]}회 → {심각도}")
    